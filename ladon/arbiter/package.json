{
  "name": "@adcp/ladon-arbiter",
  "version": "0.1.0",
  "description": "Ladon arbiter — decides approve/request-changes/comment/escalate from reviewer findings.",
  "type": "module",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/generate-rules.mjs",
    "build": "../../node_modules/.bin/ncc build src/index.ts -o dist",
    "format": "../../node_modules/.bin/biome format --write src",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
